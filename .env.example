# Copy to .env and fill in real values. Never commit .env.
# mise loads this automatically via mise.toml.

# --- OpenTofu S3 backend (Hetzner Object Storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- OpenTofu state encryption ---
TF_VAR_state_passphrase=

# --- OpenTofu provider credentials ---
TF_VAR_hcloud_token=
TF_VAR_cloudflare_api_token=
TF_VAR_cloudflare_zone_id=
TF_VAR_cloudflare_account_id=

# --- Server config ---
TF_VAR_ssh_public_key_path=~/.ssh/id_ed25519.pub
TF_VAR_admin_email=cloudflare@raveh.dev

# --- Komodo ---
# First-boot-only admin password (seeded via KOMODO_INIT_ADMIN_PASSWORD). Rotate
# through the Komodo UI afterwards — changing this variable later is a no-op.
TF_VAR_komodo_bootstrap_password=
