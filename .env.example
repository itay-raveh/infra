# Copy to .env and fill in real values. Never commit .env.
# See docs/setup.md §6.B for the full bootstrap sequence.

# Hetzner Cloud API token (Read & Write)  - create at console.hetzner.com → Security → API Tokens
TF_VAR_hcloud_token=

# Hetzner Object Storage S3 credential for the tofu state bucket  - create at console.hetzner.com → Object Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# State encryption passphrase  - do NOT set by hand. mise run tofu-apply decrypts tofu/encryption-passphrase.sops.txt and exports it.
TF_ENCRYPTION_PASSPHRASE=

# Cloudflare API token scoped to Zone:DNS edit + Zero Trust edit on raveh.dev  - create at dash.cloudflare.com → My Profile → API Tokens
TF_VAR_cloudflare_api_token=

# Cloudflare zone ID for raveh.dev  - found on the zone overview page in the Cloudflare dashboard
TF_VAR_cloudflare_zone_id=

# Path to the SSH public key used for Hetzner rescue mode break-glass (not used by Talos normally)
TF_VAR_ssh_public_key_path=

# Path to the age-plugin-yubikey identity stub file (not a plaintext key  - actual key material stays on the YubiKey)
SOPS_AGE_KEY_FILE=
