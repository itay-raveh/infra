# Copy to .env and fill in. See docs/setup.md.

# Hetzner Cloud API token (Read & Write)
TF_VAR_hcloud_token=

# S3 credential for the Hetzner Object Storage tfstate bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cloudflare API token (Zone:DNS edit + Zero Trust edit on raveh.dev)
TF_VAR_cloudflare_api_token=
TF_VAR_cloudflare_zone_id=
TF_VAR_cloudflare_account_id=

# Primary YubiKey FIDO2-sk pubkey (e.g. ~/.ssh/id_ed25519_sk.pub)
# Used only for Hetzner rescue-mode break-glass.
TF_VAR_ssh_public_key_path=

# age-plugin-yubikey identity stub
SOPS_AGE_KEY_FILE=
